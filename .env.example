# ListHQ — Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is already in .gitignore.

# ─── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# ─── Maps ────────────────────────────────────────────────────────────────────
# Browser-safe Maps API key (HTTP referrer restricted to listhq.com.au)
VITE_GOOGLE_MAPS_BROWSER_KEY=your-google-maps-browser-api-key

# ─── Auth ────────────────────────────────────────────────────────────────────
VITE_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# ─── Monitoring ──────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ─── Integrations ────────────────────────────────────────────────────────────
VITE_CALENDLY_URL=https://calendly.com/your-handle
