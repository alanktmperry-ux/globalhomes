# ============================================================
# ListHQ — Environment Variables
# ============================================================
# This file documents every env var the codebase reads.
# Copy to .env.local for local dev. Set the same values in
# Lovable project settings (frontend) and Supabase Edge
# Function secrets (server-side) for production.
#
# Frontend vars are prefixed VITE_ and are injected at build
# time by Vite. They are PUBLIC — anything VITE_-prefixed
# ships to the browser bundle. Only put referrer-restricted
# or otherwise non-secret values here.
#
# Server-side vars (used by edge functions) are NOT prefixed
# and live ONLY in Supabase. Set them via:
#   Supabase Dashboard → Edge Functions → Secrets
# ============================================================


# ────────────────────────────────────────────────────────────
# FRONTEND (Vite — set in Lovable project settings)
# ────────────────────────────────────────────────────────────

# Supabase project — public values, safe to ship to browser
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# Google Maps browser key — MUST be referrer-restricted in Google Cloud
# (allowed referrers: listhq.com.au, *.lovable.app, localhost).
# Server-side Maps calls use GOOGLE_MAPS_API_KEY (below) which is unrestricted.
VITE_GOOGLE_MAPS_BROWSER_KEY=YOUR_REFERRER_RESTRICTED_KEY

# hCaptcha site key — paired with HCAPTCHA_SECRET_KEY (server-side, below).
# Without a real key, the codebase falls back to the test sitekey
# which provides ZERO bot protection.
VITE_HCAPTCHA_SITE_KEY=YOUR_HCAPTCHA_SITE_KEY


# ============================================================
# SERVER-SIDE — Supabase Edge Function Secrets
# Set in: Supabase Dashboard → Edge Functions → Secrets
# Never commit real values, never ship to the browser.
# ============================================================

# ── Supabase server keys ────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── App URLs (used in email templates, redirects, CORS) ─────
APP_URL=https://listhq.com.au
PUBLIC_APP_URL=https://listhq.com.au
SITE_URL=https://listhq.com.au

# ── Stripe (subscriptions + webhooks) ───────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=hello@listhq.com.au
ADMIN_EMAIL=alan@listhq.com.au

# ── SMS (Twilio — optional, for SMS drip sequences) ─────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+61...

# ── AI providers ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=...
LOVABLE_API_KEY=...
LOVABLE_SEND_URL=https://...
MANUS_API_KEY=...

# ── Google Maps server key (unrestricted; do NOT ship) ──────
GOOGLE_MAPS_API_KEY=YOUR_UNRESTRICTED_GOOGLE_MAPS_KEY

# ── hCaptcha server secret ──────────────────────────────────
HCAPTCHA_SECRET_KEY=YOUR_HCAPTCHA_SECRET

# ── Internal / cron / health ────────────────────────────────
# CRON_SECRET — used by pg_cron jobs to authenticate to edge functions
# (the pg_cron migration sends this in the x-cron-secret header).
CRON_SECRET=listhq-cron-CHANGE-ME
INTERNAL_SECRET=CHANGE-ME-INTERNAL-SHARED-SECRET
HEALTH_CHECK_SECRET=CHANGE-ME

# ── Unsubscribe links (HMAC-signed token secret) ────────────
# DO NOT ship blank — the codebase falls back to 'fallback-secret'
# which makes unsubscribe links forgeable.
UNSUBSCRIBE_SECRET=GENERATE-A-LONG-RANDOM-VALUE

# ── Demo / seed data (only used in dev/demo seeding) ────────
SEED_AGENT_ID=
SEED_SECRET=
DEMO_ACCOUNT_PASSWORD=
MERIDIAN_DEMO_PASSWORD=
