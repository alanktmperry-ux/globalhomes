{
  "ci": {
    "collect": {
      "url": ["https://listhq.com.au/"],
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate"
      },
      "numberOfRuns": 3
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.95 }],
        "categories:accessibility": ["warn", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.95 }],
        "categories:seo": ["warn", { "minScore": 0.95 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 1800 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.05 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 200 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1200 }],
        "speed-index": ["warn", { "maxNumericValue": 2500 }],
        "total-byte-weight": ["warn", { "maxNumericValue": 1500000 }],
        "unused-javascript": ["warn", { "maxNumericValue": 100000 }],
        "uses-text-compression": ["warn", { "minScore": 1 }],
        "uses-optimized-images": ["warn", { "minScore": 0.9 }],
        "uses-webp-images": ["warn", { "minScore": 0.9 }],
        "uses-responsive-images": ["warn", { "minScore": 0.9 }],
        "render-blocking-resources": ["warn", { "maxNumericValue": 200 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
